# Dev-only env knobs. Loaded by `npm run dev` on top of `.env`, so values
# here override the same keys in .env. Production / `npm start` does NOT
# read this file. Safe to commit — no secrets here, only tunables that
# loosen security floors for local testing.

# Print magic links to stderr when SMTP is unreachable. Without this,
# you can't log in locally unless you run an SMTP server on :1025.
KNOWLESS_DEV_LOG_LINKS=true

# Knowless caps new-handle creation per IP per hour to deter sockpuppet
# brigading. Default is 3 — fine for prod, hostile to dev where you
# create dozens of test accounts from localhost. Bumped to 100 here so
# manual testing isn't blocked by the cap. Existing handles are not
# affected by this knob; only first-login (handle creation) is.
KNOWLESS_MAX_NEW_HANDLES_PER_IP_PER_HOUR=100
