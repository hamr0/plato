# Generate with: bin/gen-secret.sh   (single source of truth for the
# "how do I generate this" incantation; safe to paste into shell.)
KNOWLESS_SECRET=

KNOWLESS_BASE_URL=http://localhost:8080
# Bare address only — no display name. knowless rejects `Name <addr>` at boot;
# the friendly sender name comes from branding.forumName in config.json.
KNOWLESS_FROM=auth@forum.local

# Mail transport.
#
# Production: set KNOWLESS_SMTP_PORT=25 and stand up postfix (with opendkim
# signing) per docs/02-features/deploy-guide.md §5. plato does NOT override
# the transport — knowless owns the mailer end to end, postfix owns delivery
# + DKIM signing, and SPF/DKIM/DMARC live at the registrar.
#
# Dev: leave KNOWLESS_SMTP_PORT=1025. knowless tries localhost:1025 (nothing
# bound), fails fast, and KNOWLESS_DEV_LOG_LINKS=true (set in .env.dev)
# prints the magic link to stderr instead of mailing it.
KNOWLESS_SMTP_HOST=localhost
KNOWLESS_SMTP_PORT=1025

PORT=8080
DB_PATH=./forum.db
