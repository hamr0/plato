# Generate with:
#   node -e "process.stdout.write(require('crypto').randomBytes(32).toString('hex'))"
KNOWLESS_SECRET=

KNOWLESS_BASE_URL=http://localhost:8080
KNOWLESS_FROM=auth@forum.local

# Mail transport.
#
# Production: install msmtp + msmtp-mta (provides /usr/sbin/sendmail), drop
# /etc/msmtprc with your relay creds, then uncomment the line below. plato
# pipes magic-link mail through the local binary; relay credentials live in
# /etc/msmtprc only — never in this file or the plato process.
#   PLATO_SENDMAIL_PATH=/usr/sbin/sendmail
#
# See docs/02-features/deploy-guide.md for the full setup including
# /etc/msmtprc templates for gmail App Password / Fastmail / Proton Bridge.
#
# Dev: leave PLATO_SENDMAIL_PATH unset. knowless attempts SMTP localhost:1025,
# fails fast, and KNOWLESS_DEV_LOG_LINKS=true (set in .env.dev) prints the
# magic link to stderr instead of mailing it.
KNOWLESS_SMTP_HOST=localhost
KNOWLESS_SMTP_PORT=1025

PORT=8080
DB_PATH=./forum.db
