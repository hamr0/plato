# /etc/msmtprc — outbound mail config for plato.
#
# This file ships with Gmail wired up as the default. To use it:
#
#   sudo cp deploy/msmtprc.example /etc/msmtprc
#   sudo $EDITOR /etc/msmtprc        # replace YOUR_EMAIL@gmail.com + APP_PASSWORD
#   sudo chown root:root /etc/msmtprc
#   sudo chmod 600 /etc/msmtprc      # msmtp REFUSES group/world-readable creds
#
# Smoke test BEFORE plato exists:
#   echo -e "Subject: msmtprc preflight\n\nhello" | sendmail you@example.com
#   tail -5 /var/log/msmtp.log       # SMTP-level errors surface here
#
# To use a different relay (Fastmail, Proton Bridge, generic), comment
# out the active Gmail block below and uncomment the alternative block
# you want at the bottom of this file.
#
# IMPORTANT: msmtp errors with "account default not found" if there is
# no uncommented `account default` block. There can be at most ONE
# `account default` active at a time.

# ─── Defaults applied to every account block ──────────────────────────
defaults
auth           on
tls            on
tls_starttls   on
tls_trust_file /etc/pki/tls/certs/ca-bundle.crt
logfile        /var/log/msmtp.log

# ─── Gmail (active default) ───────────────────────────────────────────
# Generate the App Password at https://myaccount.google.com/apppasswords
# (2FA must be on for App Passwords to be available). Replace BOTH the
# `from` and `user` lines with your full Gmail address; replace the
# password with the 16-char App Password (with or without dashes works).
account        default
host           smtp.gmail.com
port           587
from           YOUR_EMAIL@gmail.com
user           YOUR_EMAIL@gmail.com
password       APP_PASSWORD_GOES_HERE


# ─── Alternatives — uncomment ONE if you swap away from Gmail ─────────
#
# Don't leave more than one `account default` block uncommented at a
# time; msmtp will use the last one but the situation is brittle.
#
# ─── Fastmail (any plan, App Password) ────────────────────────────────
# Generate the App Password at:
#   https://app.fastmail.com/settings/security/devicekeys
#
# account        default
# host           smtp.fastmail.com
# port           587
# from           you@fastmail.com
# user           you@fastmail.com
# password       xxxxxxxxxxxxxxxx
#
# ─── Proton Mail (via Proton Bridge running on the same box) ──────────
# Proton requires you to run their Bridge daemon — Proton Mail does
# not expose plain SMTP on the public internet. Bridge listens on
# localhost; auth/TLS to Proton happens inside the Bridge process.
# Install Bridge from https://proton.me/mail/bridge then:
#
# account        default
# host           127.0.0.1
# port           1025
# from           you@proton.me
# user           you@proton.me
# password       <bridge-generated password>
# tls            off
# auth           plain
#
# ─── Generic STARTTLS relay (work email, self-hosted, ISP) ────────────
#
# account        default
# host           smtp.example.com
# port           587
# from           plato@example.com
# user           plato@example.com
# password       <relay password>
